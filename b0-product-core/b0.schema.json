{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "b0.schema.json",
  "title": "AISMM Bundle 0 — Product Core Schema",
  "description": "Full data schema for AISMM Bundle 0: Product Core (Definition, Value & Economics). This schema expands all required Bundle 0 layers into one machine-readable JSON structure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "bundle_key",
    "bundle_name",
    "schema_version",
    "layers"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "const": "b0"
    },
    "bundle_key": {
      "type": "string",
      "const": "product_core"
    },
    "bundle_name": {
      "type": "string",
      "const": "Product Core (Definition, Value & Economics)"
    },
    "schema_version": {
      "type": "string",
      "description": "Version of this Bundle 0 schema."
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "module_scope": {
      "$ref": "#/$defs/module_scope"
    },
    "layers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "001_product_definition_context",
        "002_aeilus_value_streams",
        "003_stakeholders_and_motivation",
        "004_business_architecture",
        "005_critical_path",
        "006_product_economics_model"
      ],
      "properties": {
        "001_product_definition_context": {
          "$ref": "#/$defs/product_definition_context_layer"
        },
        "002_aeilus_value_streams": {
          "$ref": "#/$defs/aeilus_value_streams_layer"
        },
        "003_stakeholders_and_motivation": {
          "$ref": "#/$defs/stakeholders_and_motivation_layer"
        },
        "004_business_architecture": {
          "$ref": "#/$defs/business_architecture_layer"
        },
        "005_critical_path": {
          "$ref": "#/$defs/critical_path_layer"
        },
        "006_product_economics_model": {
          "$ref": "#/$defs/product_economics_layer"
        }
      }
    },
    "cross_layer_links": {
      "type": "array",
      "description": "Optional explicit links between entities of different Bundle 0 layers.",
      "items": {
        "$ref": "#/$defs/cross_layer_link"
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "module_scope": {
      "type": "string",
      "pattern": "^(root|module:[A-Za-z0-9._-]+)$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$",
      "description": "Stable AISMM identifier, e.g. product.orkestron_ai or module.billing."
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "reference": {
      "type": "string",
      "description": "Reference to another AISMM entity or external file, e.g. entity.workflow or file:vss.schema.json."
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "uniqueItems": true
    },
    "tag_list": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "entity_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "owner": {
          "$ref": "#/$defs/reference"
        },
        "references": {
          "$ref": "#/$defs/references"
        },
        "tags": {
          "$ref": "#/$defs/tag_list"
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "relation",
        "target"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "source": {
          "$ref": "#/$defs/reference"
        },
        "relation": {
          "type": "string"
        },
        "target": {
          "$ref": "#/$defs/reference"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "cross_layer_link": {
      "allOf": [
        {
          "$ref": "#/$defs/relationship"
        },
        {
          "type": "object",
          "properties": {
            "source_layer": {
              "type": "string",
              "pattern": "^\\d{3}$"
            },
            "target_layer": {
              "type": "string",
              "pattern": "^\\d{3}$"
            }
          }
        }
      ]
    },
    "product_definition_context_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_id",
        "layer_key",
        "product",
        "scope",
        "out_of_scope"
      ],
      "properties": {
        "layer_id": {
          "type": "string",
          "const": "001"
        },
        "layer_key": {
          "type": "string",
          "const": "product_definition_context"
        },
        "product": {
          "$ref": "#/$defs/product"
        },
        "scope": {
          "$ref": "#/$defs/product_scope"
        },
        "out_of_scope": {
          "$ref": "#/$defs/out_of_scope"
        },
        "modules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/product_module"
          }
        },
        "external_systems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/external_system"
          }
        },
        "channels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/channel"
          }
        },
        "environments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/environment"
          }
        },
        "ownership_zones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ownership_zone"
          }
        },
        "boundary_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boundary_rule"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/assumption"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/constraint"
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        }
      }
    },
    "product": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "required": [
            "type",
            "mission"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "application",
                "platform",
                "internal_system",
                "api_product",
                "marketplace",
                "service",
                "product_family",
                "subsystem",
                "other"
              ]
            },
            "mission": {
              "type": "string"
            },
            "primary_repository": {
              "type": "string"
            },
            "lifecycle_status": {
              "type": "string"
            }
          }
        }
      ]
    },
    "product_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "core_capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "included_modules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "supported_channels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "owned_interfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "owned_data_domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "owned_operational_responsibilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    },
    "out_of_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "excluded_capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "external_responsibilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "unsupported_channels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "non_product_domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      }
    },
    "product_module": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "role_in_product": {
              "type": "string"
            },
            "has_own_smm": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "external_system": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "relationship_to_product": {
              "type": "string",
              "enum": [
                "dependency",
                "integration",
                "shared_platform",
                "third_party_service",
                "regulatory_context",
                "adjacent_product",
                "other"
              ]
            }
          }
        }
      ]
    },
    "channel": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "channel_type": {
              "type": "string",
              "enum": [
                "web_app",
                "admin_interface",
                "public_api",
                "internal_api",
                "cli",
                "mobile_app",
                "integration",
                "other"
              ]
            }
          }
        }
      ]
    },
    "environment": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "environment_type": {
              "type": "string",
              "enum": [
                "production",
                "staging",
                "development",
                "test",
                "customer_hosted",
                "cloud_region",
                "on_premise",
                "other"
              ]
            }
          }
        }
      ]
    },
    "ownership_zone": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        }
      ]
    },
    "boundary_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement",
        "rationale"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "statement": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "affected_entities": {
          "$ref": "#/$defs/references"
        },
        "consequences": {
          "type": "string"
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "statement": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "supported_entities": {
          "$ref": "#/$defs/references"
        }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "statement": {
          "type": "string"
        },
        "constraint_type": {
          "type": "string",
          "enum": [
            "technical",
            "organizational",
            "legal",
            "compliance",
            "economic",
            "operational",
            "data",
            "other"
          ]
        },
        "affected_entities": {
          "$ref": "#/$defs/references"
        }
      }
    },
    "aeilus_value_streams_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_id",
        "layer_key",
        "value_elements",
        "converters",
        "flows"
      ],
      "properties": {
        "layer_id": {
          "type": "string",
          "const": "002"
        },
        "layer_key": {
          "type": "string",
          "const": "aeilus_value_streams"
        },
        "value_elements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/value_element"
          }
        },
        "converters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/converter"
          }
        },
        "flows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/value_flow"
          }
        },
        "participants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/value_participant"
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        }
      }
    },
    "value_element": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "value",
                "anti_value"
              ]
            },
            "value_type": {
              "type": "string",
              "enum": [
                "functional",
                "economic",
                "experiential",
                "informational",
                "strategic",
                "risk_reduction",
                "other"
              ]
            },
            "unit": {
              "type": "string"
            },
            "measured_by": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/reference"
              }
            }
          }
        }
      ]
    },
    "converter": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "converter_type": {
              "type": "string",
              "enum": [
                "product_module",
                "process",
                "actor",
                "system",
                "function",
                "external",
                "other"
              ]
            },
            "consumes": {
              "$ref": "#/$defs/references"
            },
            "produces": {
              "$ref": "#/$defs/references"
            },
            "maps_to": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "value_flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "source",
        "target",
        "value_elements"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/reference"
        },
        "target": {
          "$ref": "#/$defs/reference"
        },
        "value_elements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "direction": {
          "type": "string",
          "enum": [
            "directed"
          ]
        },
        "metrics": {
          "$ref": "#/$defs/references"
        }
      }
    },
    "value_participant": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "participant_type": {
              "type": "string",
              "enum": [
                "internal",
                "external",
                "human",
                "system",
                "conceptual",
                "organization",
                "other"
              ]
            },
            "evaluates": {
              "$ref": "#/$defs/references"
            },
            "affected_by": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "metric": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "metric_type": {
              "type": "string",
              "enum": [
                "value",
                "anti_value",
                "efficiency",
                "quality",
                "economic",
                "runtime",
                "other"
              ]
            },
            "unit": {
              "type": "string"
            },
            "formula": {
              "type": "string"
            }
          }
        }
      ]
    },
    "stakeholders_and_motivation_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_id",
        "layer_key",
        "stakeholders",
        "goals",
        "value_perceptions"
      ],
      "properties": {
        "layer_id": {
          "type": "string",
          "const": "003"
        },
        "layer_key": {
          "type": "string",
          "const": "stakeholders_and_motivation"
        },
        "stakeholders": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stakeholder"
          }
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stakeholder_role"
          }
        },
        "goals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/goal"
          }
        },
        "motivations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/motivation"
          }
        },
        "value_perceptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/value_perception"
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        }
      }
    },
    "stakeholder": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "stakeholder_type": {
              "type": "string",
              "enum": [
                "user",
                "customer",
                "operator",
                "internal_team",
                "external_organization",
                "partner",
                "regulator",
                "system",
                "other"
              ]
            },
            "roles": {
              "$ref": "#/$defs/references"
            },
            "goals": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "stakeholder_role": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        }
      ]
    },
    "goal": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "success_criteria": {
              "type": "string"
            },
            "driven_by": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "motivation": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        }
      ]
    },
    "value_perception": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "stakeholder",
        "perceived_value"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "stakeholder": {
          "$ref": "#/$defs/reference"
        },
        "perceived_value": {
          "$ref": "#/$defs/reference"
        },
        "perceived_anti_value": {
          "$ref": "#/$defs/reference"
        },
        "description": {
          "type": "string"
        },
        "evaluation_criteria": {
          "type": "string"
        }
      }
    },
    "business_architecture_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_id",
        "layer_key",
        "domains",
        "capabilities",
        "business_entities"
      ],
      "properties": {
        "layer_id": {
          "type": "string",
          "const": "004"
        },
        "layer_key": {
          "type": "string",
          "const": "business_architecture"
        },
        "domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/business_domain"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/business_capability"
          }
        },
        "business_entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/business_entity"
          }
        },
        "ownership_zones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ownership_zone"
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        }
      }
    },
    "business_domain": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "owned_capabilities": {
              "$ref": "#/$defs/references"
            },
            "related_entities": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "business_capability": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "required": [
            "domain"
          ],
          "properties": {
            "domain": {
              "$ref": "#/$defs/reference"
            },
            "conceptual_inputs": {
              "$ref": "#/$defs/references"
            },
            "conceptual_outputs": {
              "$ref": "#/$defs/references"
            },
            "related_entities": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "business_entity": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
