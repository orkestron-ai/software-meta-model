{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeilus.tech/vss-editor/schema/aeilus-vss.schema.json",
  "title": "Æilus Value System Schema (VSS)",
  "description": "JSON export/import format for Æilus Value System Schema Editor (ÆVSSE).",
  "type": "object",
  "required": ["schema", "nodes", "flows", "elements", "texts"],
  "additionalProperties": false,

  "properties": {
    "schema": {
      "$ref": "#/$defs/SchemaMeta"
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/Node" }
    },
    "flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/Flow" }
    },
    "elements": {
      "type": "array",
      "description": "Element types (value / anti-value) defined at converter level and routed into flows.",
      "items": { "$ref": "#/$defs/ElementType" }
    },
    "texts": {
      "type": "array",
      "description": "Text annotations placed on the canvas.",
      "items": { "$ref": "#/$defs/TextObject" }
    }
  },

  "$defs": {
    "SchemaMeta": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "version",
        "author",
        "created_at",
        "updated_at"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "description": "Editor/model version string, e.g. 2.4.0"
        },
        "author": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "Point": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },

    "Size": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "number",
          "minimum": 1
        },
        "height": {
          "type": "number",
          "minimum": 1
        }
      }
    },

    "Node": {
      "type": "object",
      "required": [
        "id",
        "name",
        "position",
        "size",
        "description",
        "bpmn_link",
        "link",
        "attributes"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "position": {
          "$ref": "#/$defs/Point"
        },
        "size": {
          "$ref": "#/$defs/Size"
        },
        "description": {
          "type": "string"
        },
        "bpmn_link": {
          "type": "string",
          "description": "Link to BPMN 2.0 process diagram for the converter."
        },
        "link": {
          "type": "string",
          "description": "External converter schema link."
        },
        "attributes": {
          "type": "object",
          "description": "Free-form extension fields.",
          "additionalProperties": true
        }
      }
    },

    "FlowType": {
      "type": "string",
      "enum": ["external_in", "external_out", "internal"]
    },

    "Flow": {
      "type": "object",
      "required": [
        "id",
        "name",
        "type",
        "source_node_id",
        "target_node_id",
        "value",
        "unit",
        "color",
        "show_label",
        "element_type_ids",
        "attributes"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/FlowType"
        },
        "source_node_id": {
          "type": ["string", "null"],
          "description": "Null means external source."
        },
        "target_node_id": {
          "type": ["string", "null"],
          "description": "Null means external target."
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "color": {
          "type": "string",
          "pattern": "^#([0-9a-fA-F]{6})$"
        },
        "show_label": {
          "type": "boolean"
        },
        "element_type_ids": {
          "type": "array",
          "description": "IDs of element types routed through this flow. Empty array may be interpreted by the editor as all or none depending on editor version/configuration.",
          "items": {
            "type": "string"
          }
        },
        "attributes": {
          "type": "object",
          "description": "Free-form extension fields.",
          "additionalProperties": true
        }
      }
    },

    "ElementKind": {
      "type": "string",
      "enum": ["value", "anti_value"]
    },

    "ElementLocation": {
      "type": "string",
      "enum": ["in_node", "in_flow"]
    },

    "ElementType": {
      "type": "object",
      "required": [
        "id",
        "name",
        "kind",
        "sign",
        "quantity",
        "unit",
        "location",
        "node_id",
        "flow_id",
        "attributes"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ElementKind"
        },
        "sign": {
          "type": "integer",
          "enum": [1, -1]
        },
        "quantity": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/ElementLocation"
        },
        "node_id": {
          "type": ["string", "null"],
          "description": "Converter that defines/owns this element type."
        },
        "flow_id": {
          "type": ["string", "null"],
          "description": "Optional direct binding to a flow; current editor mostly uses flow.element_type_ids instead."
        },
        "attributes": {
          "type": "object",
          "description": "Free-form extension fields.",
          "additionalProperties": true
        }
      }
    },

    "TextObject": {
      "type": "object",
      "required": ["id", "x", "y", "text"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "text": {
          "type": "string"
        }
      }
    }
  }
}
