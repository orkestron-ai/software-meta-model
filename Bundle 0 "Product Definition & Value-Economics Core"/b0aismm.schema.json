{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "b0aismm.schema.json",
  "title": "AISMM Bundle 0 Schema",
  "description": "Schema for Bundle 0: Product Definition & Value-Economics Core. This bundle aggregates the core product definition, value, business, and economics layers into a single machine-readable section of AISMM.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "bundle_key",
    "bundle_name",
    "version",
    "layers"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "const": "b0"
    },
    "bundle_key": {
      "type": "string",
      "const": "product_definition_value_economics_core"
    },
    "bundle_name": {
      "type": "string",
      "const": "Product Definition & Value-Economics Core"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "description": {
      "type": "string"
    },
    "module_scope": {
      "type": "string",
      "description": "Scope of this bundle snapshot, for example root or module:<module_id>.",
      "pattern": "^(root|module:[A-Za-z0-9._-]+)$"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "layers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "001",
        "002",
        "003",
        "004",
        "005",
        "006"
      ],
      "properties": {
        "001": {
          "$ref": "#/$defs/layer_001_value_streams"
        },
        "002": {
          "$ref": "#/$defs/layer_002_product_definition_context"
        },
        "003": {
          "$ref": "#/$defs/layer_003_stakeholders"
        },
        "004": {
          "$ref": "#/$defs/layer_004_business_architecture"
        },
        "005": {
          "$ref": "#/$defs/layer_005_critical_path"
        },
        "006": {
          "$ref": "#/$defs/layer_006_pnl_model"
        }
      }
    }
  },
  "$defs": {
    "layer_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_id",
        "layer_key",
        "document_id",
        "document_type"
      ],
      "properties": {
        "layer_id": {
          "type": "string",
          "pattern": "^\\d{3}$"
        },
        "layer_key": {
          "type": "string"
        },
        "document_id": {
          "type": "string"
        },
        "document_type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "file": {
          "type": "string",
          "description": "Relative file path to the source markdown or native format document."
        },
        "role": {
          "type": "string",
          "enum": [
            "primary",
            "supporting",
            "reference"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "deprecated",
            "archived"
          ]
        },
        "format": {
          "type": "string",
          "enum": [
            "markdown",
            "json",
            "yaml",
            "xml",
            "other"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "layer_001_value_streams": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document",
        "schema"
      ],
      "properties": {
        "document": {
          "allOf": [
            {
              "$ref": "#/$defs/layer_ref"
            },
            {
              "properties": {
                "layer_id": {
                  "const": "001"
                },
                "layer_key": {
                  "const": "aeilus_value_streams"
                },
                "document_type": {
                  "const": "value_streams"
                }
              }
            }
          ]
        },
        "schema": {
          "type": "string",
          "description": "Path to the canonical VSS schema file.",
          "default": "vss.schema.json"
        },
        "graph_kind": {
          "type": "string",
          "const": "vss"
        }
      }
    },
    "layer_002_product_definition_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document"
      ],
      "properties": {
        "document": {
          "allOf": [
            {
              "$ref": "#/$defs/layer_ref"
            },
            {
              "properties": {
                "layer_id": {
                  "const": "002"
                },
                "layer_key": {
                  "const": "product_definition_context"
                },
                "document_type": {
                  "const": "product_definition"
                }
              }
            }
          ]
        },
        "product_card_enabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "layer_003_stakeholders": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document"
      ],
      "properties": {
        "document": {
          "allOf": [
            {
              "$ref": "#/$defs/layer_ref"
            },
            {
              "properties": {
                "layer_id": {
                  "const": "003"
                },
                "layer_key": {
                  "const": "stakeholders_and_motivation"
                },
                "document_type": {
                  "const": "stakeholders"
                }
              }
            }
          ]
        }
      }
    },
    "layer_004_business_architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document"
      ],
      "properties": {
        "document": {
          "allOf": [
            {
              "$ref": "#/$defs/layer_ref"
            },
            {
              "properties": {
                "layer_id": {
                  "const": "004"
                },
                "layer_key": {
                  "const": "business_architecture_static"
                },
                "document_type": {
                  "const": "business_architecture"
                }
              }
            }
          ]
        }
      }
    },
    "layer_005_critical_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document"
      ],
      "properties": {
        "document": {
          "allOf": [
            {
              "$ref": "#/$defs/layer_ref"
            },
            {
              "properties": {
                "layer_id": {
                  "const": "005"
                },
                "layer_key": {
                  "const": "critical_path_high_level"
                },
                "document_type": {
                  "const": "critical_path"
                }
              }
            }
          ]
        }
      }
    },
    "layer_006_pnl_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document"
      ],
      "properties": {
        "document": {
          "allOf": [
            {
              "$ref": "#/$defs/layer_ref"
            },
            {
              "properties": {
                "layer_id": {
                  "const": "006"
                },
                "layer_key": {
                  "const": "product_pnl_model"
                },
                "document_type": {
                  "const": "pnl_model"
                }
              }
            }
          ]
        },
        "schema": {
          "type": "string",
          "description": "Path to the canonical P&L schema file.",
          "default": "pnl.schema.json"
        }
      }
    }
  },
  "examples": [
    {
      "bundle_id": "b0",
      "bundle_key": "product_definition_value_economics_core",
      "bundle_name": "Product Definition & Value-Economics Core",
      "version": "1.0.0",
      "status": "active",
      "module_scope": "root",
      "layers": {
        "001": {
          "document": {
            "layer_id": "001",
            "layer_key": "aeilus_value_streams",
            "document_id": "value.streams.definition",
            "document_type": "value_streams",
            "title": "Aeilus Value Streams (VSS)",
            "file": "Value_Streams.md",
            "role": "primary",
            "status": "active",
            "format": "markdown",
            "references": [
              "file:vss.schema.json"
            ]
          },
          "schema": "vss.schema.json",
          "graph_kind": "vss"
        },
        "002": {
          "document": {
            "layer_id": "002",
            "layer_key": "product_definition_context",
            "document_id": "product.definition.context",
            "document_type": "product_definition",
            "title": "Product Definition & Context",
            "file": "Product-Definition-n-Context.md",
            "role": "primary",
            "status": "active",
            "format": "markdown"
          },
          "product_card_enabled": true
        },
        "003": {
          "document": {
            "layer_id": "003",
            "layer_key": "stakeholders_and_motivation",
            "document_id": "stakeholders.definition",
            "document_type": "stakeholders",
            "title": "Stakeholders and Motivation",
            "file": "Stakeholders.md",
            "role": "primary",
            "status": "active",
            "format": "markdown"
          }
        },
        "004": {
          "document": {
            "layer_id": "004",
            "layer_key": "business_architecture_static",
            "document_id": "business.architecture.core",
            "document_type": "business_architecture",
            "title": "Business Architecture (Static)",
            "file": "Business-Architecture.md",
            "role": "primary",
            "status": "active",
            "format": "markdown"
          }
        },
        "005": {
          "document": {
            "layer_id": "005",
            "layer_key": "critical_path_high_level",
            "document_id": "critical.path.primary",
            "document_type": "critical_path",
            "title": "Critical Path (High-Level)",
            "file": "Critical-Path.md",
            "role": "primary",
            "status": "active",
            "format": "markdown"
          }
        },
        "006": {
          "document": {
            "layer_id": "006",
            "layer_key": "product_pnl_model",
            "document_id": "economics.pnl.model",
            "document_type": "pnl_model",
            "title": "Product P&L Model",
            "file": "PnL-Model.md",
            "role": "primary",
            "status": "active",
            "format": "markdown",
            "references": [
              "file:pnl.schema.json"
            ]
          },
          "schema": "pnl.schema.json"
        }
      }
    }
  ]
}
