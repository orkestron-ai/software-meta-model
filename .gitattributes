# Normalize line endings to LF on commit for all text files.
# Without this, a Windows checkout rewrites every file to CRLF and the whole
# tree shows up as "modified" on a Linux/macOS checkout (and vice versa).
* text=auto eol=lf

# Be explicit about the text formats AISMM ships.
*.md     text eol=lf
*.markdown text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.cff    text eol=lf
*.xsd    text eol=lf
*.xml    text eol=lf
*.txt    text eol=lf
LICENSE  text eol=lf
NOTICE   text eol=lf

# Binary assets — never normalize.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.pdf    binary
*.ico    binary
