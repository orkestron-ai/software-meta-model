        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "source_type": {
              "type": "string",
              "enum": [
                "technical",
                "business",
                "operational",
                "external",
                "human",
                "vendor",
                "regulatory",
                "other"
              ]
            },
            "related_entities": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "risk_event": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "risk": {
              "$ref": "#/$defs/reference"
            },
            "scenario": {
              "type": "string"
            },
            "impact_description": {
              "type": "string"
            },
            "triggers": {
