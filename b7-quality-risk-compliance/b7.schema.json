            },
            "risk_events": {
              "$ref": "#/$defs/references"
            },
            "threatens_values": {
              "$ref": "#/$defs/references"
            },
            "affects_components": {
              "$ref": "#/$defs/references"
            },
            "may_cause_incidents": {
              "$ref": "#/$defs/references"
            },
            "overlaps_with_threats": {
              "$ref": "#/$defs/references"
            },
