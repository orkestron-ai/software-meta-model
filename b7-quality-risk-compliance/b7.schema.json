{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "b7.schema.json",
  "title": "AISMM Bundle 7 — Quality, Risk & Compliance Schema",
  "description": "Full data schema for AISMM Bundle 7: Quality, Risk & Compliance (Quality Assurance, Risk Management, Security & Privacy, Compliance & Audit).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "bundle_key",
    "bundle_name",
    "schema_version",
    "layers"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "const": "b7"
    },
    "bundle_key": {
      "type": "string",
      "const": "quality_risk_compliance"
    },
    "bundle_name": {
      "type": "string",
      "const": "Quality, Risk & Compliance (QA, Risk, Security, Privacy & Audit)"
    },
    "schema_version": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "module_scope": {
      "$ref": "#/$defs/module_scope"
    },
    "layers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "701_quality_assurance_and_testing",
        "702_risk_management",
        "703_security_and_privacy",
        "704_compliance_and_audit"
      ],
      "properties": {
        "701_quality_assurance_and_testing": {
          "$ref": "#/$defs/quality_assurance_testing_layer"
        },
        "702_risk_management": {
          "$ref": "#/$defs/risk_management_layer"
        },
        "703_security_and_privacy": {
          "$ref": "#/$defs/security_privacy_layer"
        },
        "704_compliance_and_audit": {
          "$ref": "#/$defs/compliance_audit_layer"
        }
      }
    },
    "cross_layer_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cross_layer_link"
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "module_scope": {
      "type": "string",
      "pattern": "^(root|module:[A-Za-z0-9._-]+)$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$",
      "description": "Stable AISMM identifier, e.g. risk.payment_failure or test_case.login_success."
    },
    "reference": {
      "type": "string"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "uniqueItems": true
    },
    "tag_list": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "entity_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "owner": {
          "$ref": "#/$defs/reference"
        },
        "references": {
          "$ref": "#/$defs/references"
        },
        "tags": {
          "$ref": "#/$defs/tag_list"
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "relation",
        "target"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "source": {
          "$ref": "#/$defs/reference"
        },
        "relation": {
          "type": "string"
        },
        "target": {
          "$ref": "#/$defs/reference"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "cross_layer_link": {
      "allOf": [
        {
          "$ref": "#/$defs/relationship"
        },
        {
          "type": "object",
          "properties": {
            "source_layer": {
              "type": "string",
              "pattern": "^\\d{3}$"
            },
            "target_layer": {
              "type": "string",
              "pattern": "^\\d{3}$"
            }
          }
        }
      ]
    },
    "quality_assurance_testing_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_id",
        "layer_key",
        "test_cases",
        "quality_gates"
      ],
      "properties": {
        "layer_id": {
          "type": "string",
          "const": "701"
        },
        "layer_key": {
          "type": "string",
          "const": "quality_assurance_and_testing"
        },
        "test_strategies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_strategy"
          }
        },
        "test_plans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_plan"
          }
        },
        "test_suites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_suite"
          }
        },
        "test_cases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_case"
          },
          "minItems": 1
        },
        "test_scenarios": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_scenario"
          }
        },
        "test_coverages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_coverage"
          }
        },
        "defects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/defect"
          }
        },
        "quality_gates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/quality_gate"
          },
          "minItems": 1
        },
        "test_environments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_environment"
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        }
      }
    },
    "test_strategy": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "test_levels": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "test_types": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "applies_to": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "test_plan": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "scope": {
              "$ref": "#/$defs/references"
            },
            "schedule": {
              "type": "string"
            },
            "environments": {
              "$ref": "#/$defs/references"
            },
            "responsibilities": {
              "$ref": "#/$defs/references"
            },
            "suites": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "test_suite": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "suite_type": {
              "type": "string",
              "enum": [
                "unit",
                "integration",
                "system",
                "e2e",
                "regression",
                "smoke",
                "performance",
                "security",
                "other"
              ]
            },
            "test_cases": {
              "$ref": "#/$defs/references"
            },
            "covers_components": {
              "$ref": "#/$defs/references"
            },
            "covers_requirements": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "test_case": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "required": [
            "test_type"
          ],
          "properties": {
            "test_type": {
              "type": "string",
              "enum": [
                "unit",
                "integration",
                "system",
                "e2e",
                "contract",
                "performance",
                "security",
                "manual",
                "other"
              ]
            },
            "preconditions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "expected_result": {
              "type": "string"
            },
            "validates_requirements": {
              "$ref": "#/$defs/references"
            },
            "validates_business_rules": {
              "$ref": "#/$defs/references"
            },
            "validates_user_scenarios": {
              "$ref": "#/$defs/references"
            },
            "executed_on_components": {
              "$ref": "#/$defs/references"
            },
            "automation_status": {
              "type": "string",
              "enum": [
                "manual",
                "automated",
                "semi_automated",
                "planned",
                "unknown"
              ]
            }
          }
        }
      ]
    },
    "test_scenario": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "flow": {
              "$ref": "#/$defs/references"
            },
            "related_user_scenario": {
              "$ref": "#/$defs/reference"
            },
            "related_process": {
              "$ref": "#/$defs/reference"
            },
            "test_cases": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "test_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "coverage_type",
        "covered_items"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "coverage_type": {
          "type": "string",
          "enum": [
            "requirements",
            "rules",
            "code",
            "scenarios",
            "components",
            "apis",
            "data",
            "other"
          ]
        },
        "covered_items": {
          "$ref": "#/$defs/references"
        },
        "covered_by_tests": {
          "$ref": "#/$defs/references"
        },
        "coverage_value": {
          "type": "number"
        },
        "coverage_unit": {
          "type": "string"
        }
      }
    },
    "defect": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "severity": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "critical",
                "blocker",
                "unknown"
              ]
            },
            "defect_status": {
              "type": "string",
              "enum": [
                "open",
                "triaged",
                "in_progress",
                "fixed",
                "verified",
                "closed",
                "reopened",
                "unknown"
              ]
            },
            "affects_requirements": {
              "$ref": "#/$defs/references"
            },
            "affects_components": {
              "$ref": "#/$defs/references"
            },
            "found_by_test": {
              "$ref": "#/$defs/reference"
            },
            "may_cause_incidents": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "quality_gate": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "gate_type": {
              "type": "string",
              "enum": [
                "release",
                "merge",
                "deployment",
                "acceptance",
                "security",
                "performance",
                "other"
              ]
            },
            "conditions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "thresholds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "blocks_releases": {
              "$ref": "#/$defs/references"
            },
            "required_coverages": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "test_environment": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "environment_type": {
              "type": "string",
              "enum": [
                "local",
                "dev",
                "test",
                "staging",
                "preprod",
                "prod",
                "synthetic",
                "other"
              ]
            },
            "runtime_environment": {
              "$ref": "#/$defs/reference"
            },
            "test_data_sets": {
              "$ref": "#/$defs/references"
            }
          }
        }
      ]
    },
    "risk_management_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_id",
        "layer_key",
        "risks",
        "mitigations"
      ],
      "properties": {
        "layer_id": {
          "type": "string",
          "const": "702"
        },
        "layer_key": {
          "type": "string",
          "const": "risk_management"
        },
        "risks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk"
          },
          "minItems": 1
        },
        "risk_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk_source"
          }
        },
        "risk_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk_event"
          }
        },
        "risk_assessments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk_assessment"
          }
        },
        "mitigations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mitigation"
          },
          "minItems": 1
        },
        "risk_controls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk_control"
          }
        },
        "residual_risks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/residual_risk"
          }
        },
        "risk_appetites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk_appetite"
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        }
      }
    },
    "risk": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_base"
        },
        {
          "type": "object",
          "properties": {
            "risk_category": {
              "type": "string",
              "enum": [
                "technical",
